# Example environment configuration for local development.
# Copy this file to .env and replace the placeholder values.

DB_HOST=localhost
DB_NAME=simra_inspired
DB_USER=postgres
DB_PASSWORD=your_password_here

# Optional: used by some scripts for local data paths
CSV_DIR=data/converted_csv
# SIMRA_BASE_DIR=/path/to/project        # only needed if raw data lives outside the repo
# SIMRA_RAW_DIR=/path/to/project/data/raw
TARGET_INTERVAL_SEC=30
MAX_CACHED_GRAPHS=2
RIDES_PER_BATCH=200
RIDES_PER_CHUNK=1000
